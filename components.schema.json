{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Shadcn UI Components Config",
  "type": "object",
  "properties": {
    "style": {
      "type": "string",
      "enum": ["default", "new-york", "modern"]
    },
    "rsc": { "type": "boolean" },
    "tsx": { "type": "boolean" },
    "tailwind": {
      "type": "object",
      "properties": {
        "config": { "type": "string" },
        "css": { "type": "string" },
        "baseColor": { "type": "string" },
        "cssVariables": { "type": "boolean" },
        "prefix": { "type": "string" }
      }
    },
    "aliases": {
      "type": "object",
      "properties": {
        "components": { "type": "string" },
        "utils": { "type": "string" },
        "ui": { "type": "string" },
        "lib": { "type": "string" },
        "hooks": { "type": "string" }
      }
    },
    "iconLibrary": {
      "type": "string",
      "enum": ["lucide", "heroicons", "feather"]
    }
  },
  "required": ["style", "tailwind", "aliases", "iconLibrary"]
}
